.wrap {
  max-width: 720rpx;
  margin: 0 auto;
}

.pad {
  padding: 20rpx 18rpx 22rpx;
}

.mt-10 {
  margin-top: 10rpx;
}
.mt-16 {
  margin-top: 16rpx;
}

/* App Bar (match Home) */
.appbar {
  position: sticky;
  top: 0;
  z-index: 30;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.appbar-inner {
  /* Reduce top whitespace to match prototype screenshots. */
  padding: calc(72rpx + env(safe-area-inset-top)) 18rpx 12rpx;
}

.building {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: rgba(37, 99, 235, 0.10);
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bldg {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-content: center;
  gap: 6rpx;
}

.bldg-win {
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: rgba(37, 99, 235, 0.92);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.35);
}

.brand {
  font-size: 40rpx;
  font-weight: 1200;
  letter-spacing: -0.02em;
  color: rgba(15, 23, 42, 0.92);
}

.main {
  min-height: 100vh;
}

.profile {
  padding: 22rpx 20rpx 18rpx;
}

.profileTop {
  align-items: center;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.10);
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  color: rgba(37, 99, 235, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 1200;
}

.name {
  font-size: 38rpx;
  font-weight: 1200;
  letter-spacing: -0.02em;
  color: rgba(15, 23, 42, 0.92);
}

.proPill {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(241, 245, 249, 0.9);
  border: 1rpx solid var(--border);
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.95);
}

.badge {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 1000;
  border: 1rpx solid var(--border);
  background: rgba(255, 255, 255, 0.95);
  color: rgba(100, 116, 139, 0.95);
}

.badge-pro {
  border-color: rgba(37, 99, 235, 0.18);
  background: rgba(37, 99, 235, 0.08);
  color: rgba(37, 99, 235, 1);
}

.badge-verified {
  border-color: rgba(16, 185, 129, 0.22);
  background: rgba(16, 185, 129, 0.10);
  color: rgba(5, 150, 105, 1);
}

.profileGrid {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(231, 238, 248, 1);
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.pCell {
  text-align: center;
  border-radius: 18rpx;
  border: 1rpx solid var(--border);
  background: rgba(248, 250, 252, 1);
  padding: 14rpx 12rpx 12rpx;
}

.pNum {
  font-size: 44rpx;
  font-weight: 1200;
  color: rgba(15, 23, 42, 0.92);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.pBlue {
  color: rgba(37, 99, 235, 1);
}

.pLab {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.90);
}

.list {
  padding: 0;
  overflow: hidden;
  border-radius: 22rpx;
}

.li {
  padding: 20rpx 20rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.14);
  background: #fff;
}
.li:last-child {
  border-bottom: none;
}

.ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 1100;
  font-size: 26rpx;
}

.ico-blue {
  background: rgba(37, 99, 235, 0.10);
  color: rgba(37, 99, 235, 1);
}
.ico-ora {
  background: rgba(234, 88, 12, 0.10);
  color: rgba(234, 88, 12, 1);
}
.ico-ind {
  background: rgba(99, 102, 241, 0.12);
  color: rgba(99, 102, 241, 1);
}
.ico-amb {
  background: rgba(251, 191, 36, 0.14);
  color: rgba(161, 98, 7, 1);
}
.ico-grn {
  background: rgba(16, 185, 129, 0.12);
  color: rgba(16, 185, 129, 1);
}

.li-title {
  font-size: 28rpx;
  font-weight: 1100;
  color: rgba(51, 65, 85, 0.92);
}

.chev {
  font-size: 48rpx;
  color: rgba(148, 163, 184, 0.7);
  font-weight: 900;
  line-height: 1;
}

.logout {
  width: 100%;
  border: 1rpx solid rgba(244, 63, 94, 0.22);
  color: rgba(244, 63, 94, 1);
  background: #fff;
}

.press:active {
  transform: scale(0.98);
}

.buildStamp {
  margin-top: 18rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 0.9);
}
