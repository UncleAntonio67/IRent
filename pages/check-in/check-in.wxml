<view class="screen">
  <view class="wrap">
    <view class="appbar glass">
      <view class="appbar-inner">
        <view class="row between center">
          <button class="navX press" bindtap="goBack">×</button>
          <view class="navTitle">办理入住</view>
          <view class="navPh"></view>
        </view>
      </view>
    </view>

    <scroll-view scroll-y enhanced bounces="false" show-scrollbar="{{false}}" class="main pad safe-b">
      <view class="muted pageSub">填写租客信息并自动生成交租计划</view>

      <view class="card pad mt-16">
        <view class="secHead">
          <view class="secIco secIcoBlue">日</view>
          <view class="subtitle">租期与费用</view>
        </view>

        <view class="formRow mt-16">
          <view class="formLab">起租日</view>
          <picker mode="date" value="{{startDate}}" bindchange="onPickStart">
            <view class="pickBox mono">{{startDate}}</view>
          </picker>
        </view>

        <view class="formRow mt-14">
          <view class="formLab">到期日</view>
          <picker mode="date" value="{{endDate}}" bindchange="onPickEnd">
            <view class="pickBox mono">{{endDate}}</view>
          </picker>
        </view>

        <view class="formRow mt-14">
          <view class="formLab">月租金基准</view>
          <view class="formRight">
            <view class="moneySign">¥</view>
            <input class="input mono" type="number" value="{{monthlyRent}}" bindinput="onRent" placeholder="如: 3000" />
          </view>
        </view>

        <view class="formRow mt-14">
          <view class="formLab">押金金额</view>
          <view class="formRight">
            <view class="moneySign">¥</view>
            <input class="input mono" type="number" value="{{deposit}}" bindinput="onDeposit" placeholder="如: 3000" />
          </view>
        </view>

        <view class="formRow mt-14">
          <view class="formLab">交租周期</view>
          <view class="seg">
            <view class="segBtn {{paymentCycle===3 ? 'segOn' : ''}}" data-cycle="3" bindtap="setCycle">季付</view>
            <view class="segBtn {{paymentCycle===6 ? 'segOn' : ''}}" data-cycle="6" bindtap="setCycle">半年付</view>
            <view class="segBtn {{paymentCycle===12 ? 'segOn' : ''}}" data-cycle="12" bindtap="setCycle">年付</view>
          </view>
        </view>
      </view>

      <view class="card pad mt-16">
        <view class="secHead">
          <view class="secIco secIcoSlt">人</view>
          <view class="subtitle">租客信息</view>
        </view>

        <view class="formRow mt-16">
          <view class="formLab">租客姓名 *</view>
          <input class="input" value="{{tenant}}" bindinput="onTenant" placeholder="例如：张先生" />
        </view>
        <view class="formRow mt-14">
          <view class="formLab">联系电话</view>
          <input class="input mono" type="number" value="{{phone}}" bindinput="onPhone" placeholder="选填" />
        </view>
        <view class="formRow mt-14">
          <view class="formLab">身份证号</view>
          <input class="input mono" value="{{idCard}}" bindinput="onIdCard" placeholder="选填" />
        </view>
      </view>

      <view class="card pad mt-16">
        <view class="secHead">
          <view class="secIco secIcoInd">合</view>
          <view class="subtitle">租赁合同附件 *</view>
        </view>

        <view class="upload mt-16 {{hasContract ? 'uploadOn' : ''}}" bindtap="pickContract">
          <view class="uploadIcon">{{hasContract ? '已' : '拍'}}</view>
          <view class="uploadTxt">
            {{hasContract ? ('已上传租赁合同 (共' + contractCount + '张)') : '点击拍照 / 上传合同扫描件'}}
          </view>
        </view>
      </view>

      <view class="card pad mt-16">
        <view class="secHead">
          <view class="secIco secIcoOra">℃</view>
          <view class="subtitle">水电规则</view>
        </view>

        <view class="formRow mt-16">
          <view class="formLab">全包在租金内</view>
          <switch checked="{{utilsInc}}" bindchange="onUtilsInc" />
        </view>

        <view wx:if="{{!utilsInc}}">
          <view class="formRow mt-14">
            <view class="formLab">水单价</view>
            <view class="formRight">
              <input class="input mono" type="number" value="{{waterPrice}}" bindinput="onWaterPrice" />
            </view>
          </view>
          <view class="formRow mt-14">
            <view class="formLab">电单价</view>
            <view class="formRight">
              <input class="input mono" type="number" value="{{electricPrice}}" bindinput="onElectricPrice" />
            </view>
          </view>
          <view class="formRow mt-14">
            <view class="formLab">初始水表</view>
            <view class="formRight">
              <input class="input mono" type="number" value="{{initWater}}" bindinput="onInitWater" />
            </view>
          </view>
          <view class="formRow mt-14">
            <view class="formLab">初始电表</view>
            <view class="formRight">
              <input class="input mono" type="number" value="{{initElectric}}" bindinput="onInitElectric" />
            </view>
          </view>
        </view>
      </view>

      <view class="card pad mt-16 payBox">
        <view class="secHead">
          <view class="secIco secIcoBlue">¥</view>
          <view class="subtitle">实时核算</view>
        </view>

        <view class="formRow mt-16">
          <view class="formLab">首期应收租金</view>
          <view class="mono bigMoney">¥{{firstExpected}}</view>
        </view>
        <view class="formRow mt-14">
          <view class="formLab">实际收取首期租金</view>
          <view class="formRight">
            <view class="moneySign">¥</view>
            <input class="input mono" type="number" value="{{firstPaidRent}}" bindinput="onFirstPaidRent" />
          </view>
        </view>
        <view class="formRow mt-14">
          <view class="formLab">首期合计 (含押金)</view>
          <view class="mono bigMoney">¥{{firstTotal}}</view>
        </view>

        <view class="muted tiny mt-14">交租计划共 {{scheduleCount}} 期，将在提交后写入房间。</view>
      </view>
    </scroll-view>

    <view class="foot glass">
      <button class="btn btn-primary full press" disabled="{{submitDisabled}}" bindtap="submit">
        {{submitText}}
      </button>
    </view>
  </view>
</view>
