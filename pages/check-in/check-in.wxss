.wrap {
  max-width: 720rpx;
  margin: 0 auto;
}

.pad {
  padding: 20rpx 18rpx 22rpx;
}

.mt-14 {
  margin-top: 14rpx;
}
.mt-16 {
  margin-top: 16rpx;
}

.safe-b {
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.appbar {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.appbar-inner {
  padding: calc(72rpx + env(safe-area-inset-top)) 18rpx 14rpx;
}

.navX {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(100, 116, 139, 0.95);
  padding: 0;
}

.navTitle {
  font-size: 30rpx;
  font-weight: 1100;
  color: rgba(15, 23, 42, 0.92);
}

.navPh {
  width: 64rpx;
  height: 64rpx;
}

.pageSub {
  font-size: 22rpx;
  font-weight: 900;
}

.secHead {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.secIco {
  width: 40rpx;
  height: 40rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 1200;
}

.secIcoBlue {
  background: rgba(37, 99, 235, 0.12);
  color: rgba(37, 99, 235, 1);
}
.secIcoSlt {
  background: rgba(148, 163, 184, 0.12);
  color: rgba(100, 116, 139, 1);
}
.secIcoInd {
  background: rgba(99, 102, 241, 0.12);
  color: rgba(99, 102, 241, 1);
}
.secIcoOra {
  background: rgba(234, 88, 12, 0.10);
  color: rgba(234, 88, 12, 1);
}

.formRow {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.formLab {
  font-size: 22rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.95);
}

.formRight {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  justify-content: flex-end;
}

.pickBox {
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  background: rgba(241, 245, 249, 0.6);
  font-weight: 1000;
  color: rgba(51, 65, 85, 0.92);
}

.moneySign {
  font-size: 22rpx;
  font-weight: 1200;
  color: rgba(100, 116, 139, 0.9);
}

.input {
  min-width: 260rpx;
  max-width: 420rpx;
  text-align: right;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  background: rgba(241, 245, 249, 0.6);
  font-weight: 1000;
  box-sizing: border-box;
}

.seg {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: rgba(148, 163, 184, 0.16);
}

.segBtn {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.9);
}

.segOn {
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
  color: rgba(37, 99, 235, 1);
}

.upload {
  width: 100%;
  padding: 28rpx 18rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(148, 163, 184, 0.35);
  background: rgba(241, 245, 249, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 10rpx;
}

.uploadOn {
  border-color: rgba(16, 185, 129, 0.45);
  background: rgba(236, 253, 245, 0.75);
}

.uploadIcon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 1200;
  color: rgba(148, 163, 184, 0.9);
}

.uploadOn .uploadIcon {
  color: rgba(16, 185, 129, 1);
  border-color: rgba(16, 185, 129, 0.20);
}

.uploadTxt {
  font-size: 24rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.95);
}

.payBox {
  border-color: rgba(37, 99, 235, 0.20);
  background: rgba(239, 246, 255, 0.55);
}

.bigMoney {
  font-size: 30rpx;
  font-weight: 1200;
  color: rgba(37, 99, 235, 1);
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.tiny {
  font-size: 20rpx;
  font-weight: 900;
}

.foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 18rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.full {
  width: 100%;
}

.press:active {
  transform: scale(0.98);
}

