.mt-16 {
  margin-top: 16rpx;
}
.mt-14 {
  margin-top: 14rpx;
}

.pick {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  background: #fff;
  font-weight: 900;
}

.inp {
  width: 380rpx;
  text-align: right;
  padding: 10rpx 0;
  font-weight: 900;
}

.money {
  font-size: 30rpx;
  font-weight: 1000;
  color: var(--primary);
}

.red {
  color: var(--danger);
}

.btn-sm {
  padding: 10rpx 14rpx;
  font-size: 24rpx;
}

.tpl {
  border: 1rpx solid var(--border);
  border-radius: 14rpx;
  background: rgba(241, 245, 249, 0.6);
  padding: 14rpx 14rpx;
  font-size: 22rpx;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
  white-space: pre-wrap;
  color: rgba(30, 41, 59, 0.85);
}

.footer {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.full {
  width: 100%;
}
