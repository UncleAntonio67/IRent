.wrap {
  max-width: 720rpx;
  margin: 0 auto;
}

.pad {
  padding: 20rpx 18rpx 22rpx;
}

.mt-14 {
  margin-top: 14rpx;
}
.mt-16 {
  margin-top: 16rpx;
}

.safe-b {
  /* Fixed footer already exists on this page; keep scroll padding just above it. */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.appbar {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.appbar-inner {
  padding: calc(72rpx + env(safe-area-inset-top)) 18rpx 14rpx;
}

.navX {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(100, 116, 139, 0.95);
  padding: 0;
}

.navTitle {
  font-size: 30rpx;
  font-weight: 1100;
  color: rgba(15, 23, 42, 0.92);
}

.navPh {
  width: 64rpx;
  height: 64rpx;
}

.pageSub {
  font-size: 22rpx;
  font-weight: 900;
}

.secHead {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.secIco {
  width: 40rpx;
  height: 40rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 1200;
}

.secIcoSlt {
  background: rgba(148, 163, 184, 0.12);
  color: rgba(100, 116, 139, 1);
}
.secIcoRose {
  background: rgba(244, 63, 94, 0.10);
  color: rgba(225, 29, 72, 1);
}
.secIcoInd {
  background: rgba(99, 102, 241, 0.12);
  color: rgba(99, 102, 241, 1);
}

.formRow {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.formLab {
  font-size: 22rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.95);
}

.pickBox {
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  background: rgba(241, 245, 249, 0.6);
  font-weight: 1000;
  color: rgba(51, 65, 85, 0.92);
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.bigDanger {
  font-size: 30rpx;
  font-weight: 1200;
  color: rgba(225, 29, 72, 1);
}

.tiny {
  font-size: 20rpx;
  font-weight: 900;
}

.ta {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 16rpx;
  padding: 16rpx 16rpx;
  background: rgba(241, 245, 249, 0.6);
  box-sizing: border-box;
  font-weight: 1000;
}

.foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 18rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.full {
  width: 100%;
}

.press:active {
  transform: scale(0.98);
}
