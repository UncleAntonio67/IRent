.screen {
  height: 100vh;
  overflow: hidden;
}

.wrap {
  max-width: 720rpx;
  margin: 0 auto;
  height: 100vh;
  display: flex;
  flex-direction: column;
  /* Avoid content being covered by the custom tab bar without creating extra scroll. */
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.top {
  flex: 0 0 auto;
}

.topSub {
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(231, 238, 248, 1);
  background: rgba(247, 249, 255, 0.96);
}

.content {
  flex: 1;
  width: 100%;
}

.contentPad {
  padding: 0 18rpx 0;
}

.gap-8 {
  gap: 8rpx;
}

.gap-10 {
  gap: 10rpx;
}

.pad {
  padding: 20rpx 18rpx 22rpx;
}

/* App Bar (match Home) */
.appbar {
  position: relative;
  z-index: 60;
  border-bottom: 1rpx solid rgba(231, 238, 248, 1);
}

.appbar-inner {
  /* Reduce top whitespace to match prototype screenshots. */
  padding: calc(72rpx + env(safe-area-inset-top)) 18rpx 12rpx;
}

.building {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: rgba(37, 99, 235, 0.10);
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bldg {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-content: center;
  gap: 6rpx;
}

.bldg-win {
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: rgba(37, 99, 235, 0.92);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.35);
}

.brand {
  font-size: 40rpx;
  font-weight: 1200;
  letter-spacing: -0.02em;
  color: rgba(15, 23, 42, 0.92);
}

.page-h2 {
  font-size: 34rpx;
  font-weight: 1100;
  color: rgba(15, 23, 42, 0.92);
}

.mt-10 {
  margin-top: 10rpx;
}
.mt-14 {
  margin-top: 14rpx;
}
.mt-16 {
  margin-top: 16rpx;
}

.gap-16 {
  gap: 16rpx;
}

.year-pill {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: #fff;
  font-size: 22rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.9);
}

.calIco {
  width: 28rpx;
  height: 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: rgba(241, 245, 249, 0.7);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.calTop {
  height: 8rpx;
  background: rgba(148, 163, 184, 0.35);
}

.calGrid {
  flex: 1;
  padding: 5rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rpx;
}

.calCell {
  border-radius: 2rpx;
  background: rgba(148, 163, 184, 0.35);
}

.dash {
  padding: 22rpx 20rpx 18rpx;
}

.dash-kicker {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.92);
}

.dash-total {
  margin-top: 8rpx;
  font-size: 72rpx;
  font-weight: 1200;
  letter-spacing: -0.03em;
  color: rgba(15, 23, 42, 0.92);
}

.dash-grid {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(231, 238, 248, 1);
  display: grid;
  grid-template-columns: 1fr 1fr 1.12fr;
  gap: 12rpx;
}

.dash-cell {
  border-radius: 18rpx;
  border: 1rpx solid rgba(231, 238, 248, 1);
  background: rgba(248, 250, 252, 1);
  padding: 14rpx 14rpx 12rpx;
}

.dash-cell.dash-warn {
  background: rgba(255, 251, 235, 0.86);
  border-color: rgba(253, 230, 138, 0.95);
}

.dash-mini {
  font-size: 18rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.92);
}

.dash-mini.warn {
  color: rgba(180, 83, 9, 1);
}

.dash-mini-val {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 1200;
  color: rgba(15, 23, 42, 0.92);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.dash-pending {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 1200;
  color: rgba(180, 83, 9, 1);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.right {
  text-align: right;
}

.seg {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 16rpx;
  background: rgba(148, 163, 184, 0.16);
}

.seg-btn {
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.9);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
  min-height: 56rpx;
}

.seg-on {
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.seg-on.pending {
  color: #e11d48;
}
.seg-on.paid {
  color: #059669;
}

.segDot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
}

.segDotRose {
  background: rgba(244, 63, 94, 1);
}

.segDotGrn {
  background: rgba(16, 185, 129, 1);
}

.seg-on.pending .segDotRose {
  background: rgba(225, 29, 72, 1);
}

.seg-on.paid .segDotGrn {
  background: rgba(5, 150, 105, 1);
}

.receipt-ico {
  width: 36rpx;
  height: 36rpx;
  border-radius: 12rpx;
  background: rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 1100;
  color: rgba(148, 163, 184, 1);
}

.item {
  padding: 20rpx 20rpx 18rpx;
  border-radius: 22rpx;
}

.item-top {
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.14);
}

.item-room {
  font-size: 32rpx;
  font-weight: 1100;
}

.item-tenant {
  font-size: 22rpx;
  font-weight: 900;
}

.item-title {
  font-size: 28rpx;
  font-weight: 1100;
}

.item-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.item-amt {
  font-size: 34rpx;
  font-weight: 1100;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
  color: rgba(15, 23, 42, 0.9);
}

.item-amt.plus {
  color: #059669;
}

.btn-sm {
  padding: 10rpx 14rpx;
  font-size: 24rpx;
}

.item-act {
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  font-weight: 1100;
  background: rgba(37, 99, 235, 1);
  color: #fff;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 26rpx rgba(37, 99, 235, 0.18);
  min-height: 56rpx;
}

.item.overdue {
  border-left: 8rpx solid rgba(244, 63, 94, 0.85);
}

.item.due {
  border-left: 8rpx solid rgba(251, 191, 36, 0.95);
}

.empty-ok {
  padding: 34rpx 22rpx;
  text-align: center;
  border-style: dashed;
}

.ok-ico {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, 0.10);
  border: 1rpx solid rgba(16, 185, 129, 0.20);
  color: rgba(16, 185, 129, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 1200;
  font-size: 36rpx;
  margin: 0 auto 18rpx;
}

.ok-big {
  font-size: 28rpx;
  font-weight: 1100;
  color: rgba(15, 23, 42, 0.82);
}
.ok-sub {
  margin-top: 10rpx;
}

.empty-muted {
  padding: 50rpx 18rpx;
  text-align: center;
  color: rgba(148, 163, 184, 0.9);
  font-weight: 1000;
}

.press:active {
  transform: scale(0.98);
}
