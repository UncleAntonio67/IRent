.wrap {
  max-width: 720rpx;
  margin: 0 auto;
}

.gap-8 {
  gap: 8rpx;
}

.gap-10 {
  gap: 10rpx;
}

.pad {
  padding: 20rpx 18rpx 22rpx;
}

.appbar {
  position: sticky;
  top: 0;
  z-index: 30;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.appbar-inner {
  padding: calc(96rpx + env(safe-area-inset-top)) 18rpx 12rpx;
}

.appbar-edit {
  padding-top: calc(96rpx + env(safe-area-inset-top) + 64rpx);
}

.edit-banner {
  position: absolute;
  top: env(safe-area-inset-top);
  left: 0;
  right: 0;
  height: 64rpx;
  border-radius: 0;
  background: rgba(251, 191, 36, 0.96);
  color: rgba(255, 255, 255, 0.98);
  font-weight: 1100;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.02em;
  gap: 10rpx;
}

.edit-gear {
  font-size: 26rpx;
  line-height: 1;
  opacity: 0.95;
}

.building {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: rgba(37, 99, 235, 0.10);
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bldg {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-content: center;
  gap: 6rpx;
}

.bldg-win {
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: rgba(37, 99, 235, 0.92);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.35);
}

.bldg-sm {
  width: 42rpx;
  height: 42rpx;
  gap: 7rpx;
}

.bldg-sm .bldg-win {
  width: 11rpx;
  height: 11rpx;
  border-radius: 3rpx;
}

.brand {
  font-size: 40rpx;
  font-weight: 1200;
  letter-spacing: -0.02em;
  color: rgba(15, 23, 42, 0.92);
}

.mode-btn {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 1100;
  background: rgba(148, 163, 184, 0.16);
  color: rgba(100, 116, 139, 0.95);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.mode-gear {
  font-size: 24rpx;
  line-height: 1;
  opacity: 0.7;
}

.mode-on {
  background: rgba(251, 191, 36, 0.96);
  color: #fff;
  box-shadow: 0 12rpx 26rpx rgba(251, 191, 36, 0.20);
}

.filters {
  margin-top: 16rpx;
}

.filters-scroll {
  width: 100%;
}

.filters-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  /* ensure horizontal layout inside scroll-view */
  padding-bottom: 2rpx;
}

.f-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 1100;
  background: rgba(148, 163, 184, 0.16);
  color: rgba(100, 116, 139, 0.95);
  white-space: nowrap;
  flex: 0 0 auto;
}

.type-overdue {
  background: rgba(254, 226, 226, 0.70);
  color: rgba(225, 29, 72, 1);
}

.type-due {
  background: rgba(254, 243, 199, 0.72);
  color: rgba(217, 119, 6, 1);
}

.type-rented {
  background: rgba(209, 250, 229, 0.72);
  color: rgba(5, 150, 105, 1);
}

.type-empty {
  background: rgba(226, 232, 240, 0.75);
  color: rgba(100, 116, 139, 1);
}

.type-all {
  background: rgba(148, 163, 184, 0.16);
  color: rgba(100, 116, 139, 0.95);
}

.f-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
}
.f-dot-rose {
  background: rgba(244, 63, 94, 1);
}
.f-dot-amber {
  background: rgba(251, 191, 36, 1);
}
.f-dot-grn {
  background: rgba(16, 185, 129, 1);
}
.f-dot-slt {
  background: rgba(148, 163, 184, 1);
}

.f-on {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.20);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}
.f-on.all {
  background: rgba(15, 23, 42, 0.92);
  color: #fff;
  border-color: rgba(15, 23, 42, 0.12);
}
.f-on.overdue {
  background: rgba(244, 63, 94, 0.92);
  color: #fff;
  border-color: rgba(244, 63, 94, 0.12);
}
.f-on.due {
  background: rgba(251, 191, 36, 0.96);
  color: #fff;
  border-color: rgba(251, 191, 36, 0.12);
}
.f-on.rented {
  background: rgba(16, 185, 129, 0.92);
  color: #fff;
  border-color: rgba(16, 185, 129, 0.12);
}
.f-on.empty {
  background: rgba(100, 116, 139, 0.92);
  color: #fff;
  border-color: rgba(100, 116, 139, 0.12);
}

.f-on.overdue .f-dot-rose {
  background: #fff;
}
.f-on.due .f-dot-amber {
  background: #fff;
}
.f-on.rented .f-dot-grn {
  background: #fff;
}
.f-on.empty .f-dot-slt {
  background: #fff;
}

.crumb {
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
  background: rgba(248, 250, 252, 0.92);
  backdrop-filter: blur(16rpx);
  position: sticky;
  top: calc(160rpx + env(safe-area-inset-top));
  z-index: 28;
}

.crumb-link {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.crumb-arrow {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  font-size: 0;
  line-height: 0;
}
.crumb-arrow::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 4rpx solid rgba(37, 99, 235, 1);
  border-bottom: 4rpx solid rgba(37, 99, 235, 1);
  transform: rotate(45deg);
  box-sizing: border-box;
}

.link {
  font-size: 26rpx;
  font-weight: 1000;
  color: var(--primary);
}

.main {
  min-height: 100vh;
}

.prop-scroll {
  width: 100%;
}

.prop-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  padding-bottom: 2rpx;
}

.prop {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: #fff;
  font-weight: 1000;
  font-size: 26rpx;
  white-space: nowrap;
}
.prop-on {
  background: rgba(15, 23, 42, 0.92);
  color: #fff;
  border-color: rgba(15, 23, 42, 0.2);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.10);
}
.prop-add {
  border-style: dashed;
  color: var(--primary);
}

.block-card {
  border-radius: 22rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
  border-color: rgba(148, 163, 184, 0.22);
}

.block-head {
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
  padding-bottom: 14rpx;
  margin-bottom: 14rpx;
}

.blk-ico {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: rgba(37, 99, 235, 0.08);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sep {
  margin: 0 10rpx;
  color: rgba(148, 163, 184, 0.45);
}

.chev {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  font-size: 0;
  line-height: 0;
}
.chev::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 9rpx;
  width: 12rpx;
  height: 12rpx;
  border-right: 4rpx solid rgba(148, 163, 184, 0.72);
  border-top: 4rpx solid rgba(148, 163, 184, 0.72);
  transform: rotate(45deg);
  box-sizing: border-box;
}

.mini {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.mini-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  align-items: center;
}
.mini-floor {
  width: 56rpx;
  text-align: right;
  font-size: 20rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.8);
}
.mini-cells {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}
.mini-cell {
  width: 22rpx;
  height: 22rpx;
  border-radius: 6rpx;
  border: 0;
  transition: opacity 280ms ease, transform 280ms ease, filter 280ms ease;
}
.mini-empty {
  background: rgba(226, 232, 240, 1);
}
.mini-rented {
  background: rgba(52, 211, 153, 1);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.35);
}
.mini-due_soon {
  background: rgba(251, 191, 36, 1);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.35);
}
.mini-overdue {
  background: rgba(244, 63, 94, 1);
  box-shadow: 0 0 14rpx rgba(244, 63, 94, 0.30);
}
.mini-dim {
  opacity: 0.15;
  filter: grayscale(100%);
  transform: scale(0.90);
}

.block-wrap {
  overflow: hidden;
  border-radius: 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border-color: rgba(148, 163, 184, 0.18);
}

.block-add {
  border: 2rpx dashed rgba(37, 99, 235, 0.35);
  background: rgba(37, 99, 235, 0.06);
}

.block-title {
  background: transparent;
  padding: 28rpx 18rpx 10rpx;
  font-weight: 1200;
  font-size: 34rpx;
  text-align: center;
  letter-spacing: -0.01em;
}

.add-line {
  margin: 18rpx;
  padding: 22rpx 18rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(37, 99, 235, 0.35);
  color: var(--primary);
  font-weight: 1000;
  background: rgba(37, 99, 235, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.add-plus {
  font-size: 44rpx;
  font-weight: 1200;
  line-height: 1;
  color: rgba(37, 99, 235, 0.95);
}

.add-text {
  font-size: 26rpx;
  font-weight: 1000;
  color: rgba(37, 99, 235, 0.95);
}

.floors {
  display: flex;
  flex-direction: column;
}

.floor-row {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid rgba(148, 163, 184, 0.10);
}
.floor-row:first-child {
  border-top: 0;
}
.floor-label {
  width: 92rpx;
  background: rgba(248, 250, 252, 1);
  padding: 18rpx 10rpx;
  font-weight: 1000;
  color: rgba(100, 116, 139, 0.9);
  border-right: 1rpx solid rgba(241, 245, 249, 1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.floor-f {
  font-size: 26rpx;
  font-weight: 1200;
  color: rgba(100, 116, 139, 0.92);
}

.floor-add {
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 1100;
  color: rgba(37, 99, 235, 0.95);
}

.floor-count {
  margin-top: 4rpx;
  font-size: 18rpx;
  font-weight: 1100;
  color: rgba(37, 99, 235, 0.65);
}

.rooms-grid {
  flex: 1;
  padding: 16rpx 16rpx 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  background: #fff;
}

.rooms-grid-edit {
  grid-template-columns: repeat(3, 1fr);
}

.rooms-grid-edit .room {
  min-height: 156rpx;
}

.room {
  position: relative;
  border-radius: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.30);
  padding: 16rpx 16rpx 14rpx;
  min-height: 156rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: opacity 280ms ease, transform 280ms ease, filter 280ms ease;
}

.room-add {
  border: 2rpx dashed rgba(37, 99, 235, 0.35);
  background: rgba(37, 99, 235, 0.06);
  color: var(--primary);
  font-size: 56rpx;
  font-weight: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-no {
  font-size: 34rpx;
  font-weight: 1100;
  letter-spacing: -0.02em;
}

.t-slate {
  color: rgba(100, 116, 139, 1);
}
.t-rose {
  color: rgba(225, 29, 72, 1);
}
.t-amber {
  color: rgba(217, 119, 6, 1);
}
.t-emerald {
  color: rgba(5, 150, 105, 1);
}

.tiny {
  font-size: 22rpx;
  font-weight: 900;
}

.rent-line {
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(100, 116, 139, 0.75);
}

.note {
  font-size: 20rpx;
  font-weight: 1000;
}

.note-danger {
  font-weight: 1100;
}

.tenant {
  opacity: 0.96;
  color: rgba(100, 116, 139, 0.92);
}

.mt-6 {
  margin-top: 6rpx;
}

.mt-10 {
  margin-top: 10rpx;
}

.danger-text {
  color: var(--danger);
}

.r-dot {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  margin-top: 0;
}
.r-dot-empty {
  background: rgba(148, 163, 184, 0.55);
}
.r-dot-rented {
  background: rgba(16, 185, 129, 0.75);
}
.r-dot-due_soon {
  background: rgba(251, 191, 36, 0.85);
}
.r-dot-overdue {
  background: rgba(244, 63, 94, 0.85);
}

.r-dot-overdue {
  box-shadow: 0 0 10rpx rgba(244, 63, 94, 0.22);
}

.r-dot-due_soon {
  box-shadow: 0 0 10rpx rgba(251, 191, 36, 0.25);
}

.r-dot-rented {
  box-shadow: 0 0 10rpx rgba(16, 185, 129, 0.22);
}

.press:active {
  transform: scale(0.98);
}

/* Prototype: static dots (no pulsing animation) */

.trash {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 0.92);
}

.status-empty {
  background: #fff;
  border-color: rgba(148, 163, 184, 0.30);
  border-style: dashed;
}
.status-rented {
  background: #fff;
  border-color: rgba(226, 232, 240, 1);
}
.status-due_soon {
  background: rgba(255, 251, 235, 0.42);
  border-color: rgba(251, 191, 36, 0.60);
}
.status-overdue {
  background: rgba(255, 241, 242, 0.40);
  border-color: rgba(244, 63, 94, 0.50);
}

.status-edit {
  background: rgba(241, 245, 249, 0.75);
  border-style: dashed;
  border-color: rgba(148, 163, 184, 0.55);
}

.empty {
  padding: 44rpx 18rpx;
  text-align: center;
  color: rgba(100, 116, 139, 0.7);
  font-weight: 900;
}
