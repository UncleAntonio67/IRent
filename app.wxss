page {
  background: #f8fafc;
  color: #1e293b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei",
    "Helvetica Neue", Arial, "Noto Sans CJK SC", sans-serif;

  /* Brand + status colors */
  --primary: #2563eb;
  --success: #10b981;
  --success-bg: #ecfdf5;
  --danger: #f43f5e;
  --danger-bg: #fff1f2;
  --warn: #fbbf24;
  --warn-bg: #fffbeb;
  --text: #1e293b;
  --muted: #94a3b8;
  --panel: #ffffff;
  /* Match prototype: subtle border + very soft shadow */
  --border: rgba(241, 245, 249, 1);
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);

  --r-xl: 18rpx;
  --r-lg: 14rpx;
  --r-md: 12rpx;
}

.safe-bottom {
  /* Custom tabbar height is ~180rpx; keep a small extra buffer. */
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* For pages/modals that have their own fixed bottom action bar. */
.safe-foot {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* Minimal safe inset only (no tabbar/footer). */
.safe-inset {
  padding-bottom: env(safe-area-inset-bottom);
}

.glass {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(226, 232, 240, 0.65);
}

.shadow-soft {
  box-shadow: var(--shadow);
}

.anim-fade-in {
  animation: fadeIn 200ms ease both;
}

.anim-slide-up {
  animation: slideUp 260ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.anim-slide-in-bottom {
  animation: slideInBottom 260ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.anim-slide-in-left {
  animation: slideInLeft 260ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.anim-slide-in-right {
  animation: slideInRight 260ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

@keyframes slideInBottom {
  from {
    transform: translateY(80rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideInLeft {
  from {
    transform: translateX(-24rpx);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slideInRight {
  from {
    transform: translateX(24rpx);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.screen {
  min-height: 100vh;
}

.card {
  background: var(--panel);
  border: 1rpx solid var(--border);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow);
}

.pad {
  padding: 24rpx;
}

.row {
  display: flex;
  flex-direction: row;
}

.col {
  display: flex;
  flex-direction: column;
}

.between {
  justify-content: space-between;
}

.center {
  align-items: center;
}

.start {
  align-items: flex-start;
}

.end {
  align-items: flex-end;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.gap-20 {
  gap: 20rpx;
}

.muted {
  color: var(--muted);
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 26rpx;
  font-weight: 900;
}

.btn {
  border-radius: var(--r-lg);
  padding: 18rpx 20rpx;
  font-weight: 900;
  font-size: 26rpx;
}

.btn-sm {
  padding: 12rpx 14rpx;
  font-size: 24rpx;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-ghost {
  background: rgba(37, 99, 235, 0.08);
  color: var(--primary);
  border: 1rpx solid rgba(37, 99, 235, 0.18);
}

.btn-danger {
  background: var(--danger);
  color: #fff;
}

.pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  background: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.pill-active {
  border-color: rgba(37, 99, 235, 0.35);
  background: rgba(37, 99, 235, 0.10);
  color: var(--primary);
}

.tag {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  border: 1rpx solid var(--border);
  background: #fff;
}

.tag-success {
  border-color: rgba(16, 185, 129, 0.35);
  background: var(--success-bg);
  color: var(--success);
}

.tag-warn {
  border-color: rgba(251, 191, 36, 0.45);
  background: var(--warn-bg);
  color: #a16207;
}

.tag-danger {
  border-color: rgba(244, 63, 94, 0.35);
  background: var(--danger-bg);
  color: var(--danger);
}

.fade-dim {
  opacity: 0.3;
  filter: grayscale(100%);
}
