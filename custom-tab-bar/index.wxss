.tab {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  pointer-events: auto;
}

.tab-inner {
  width: 85%;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 26rpx;
  box-shadow: 0 16rpx 70rpx rgba(15, 23, 42, 0.14);
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 18rpx 14rpx;
}

.item {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-radius: 18rpx;
  padding: 10rpx 10rpx;
  color: rgba(148, 163, 184, 1);
}

.on {
  color: rgba(37, 99, 235, 1);
}

.icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 1000;
  font-size: 24rpx;
  color: rgba(148, 163, 184, 1);
}

.icon-on {
  background: rgba(37, 99, 235, 0.12);
  color: rgba(37, 99, 235, 1);
}

.label {
  font-size: 20rpx;
  font-weight: 1000;
}

