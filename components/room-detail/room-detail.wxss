.overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.40);
  display: flex;
  align-items: flex-end;
  z-index: 500;
}

.sheet {
  width: 100%;
  max-height: 92vh;
  background: #f8fafc;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  box-shadow: 0 -20rpx 80rpx rgba(15, 23, 42, 0.18);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.handle {
  width: 88rpx;
  height: 12rpx;
  background: rgba(148, 163, 184, 0.40);
  border-radius: 999rpx;
  margin: 16rpx auto 10rpx;
}

.head {
  background: #fff;
  padding: 14rpx 18rpx 10rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.roomNo {
  font-size: 46rpx;
  font-weight: 1200;
  letter-spacing: -0.02em;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  color: rgba(100, 116, 139, 0.95);
}

.iconBtn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.iconBtnBlue {
  background: rgba(37, 99, 235, 0.10);
  border-color: rgba(37, 99, 235, 0.14);
}

.iconBtnIn {
  font-size: 28rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.95);
  line-height: 1;
}

.iconBtnBlue .iconBtnIn {
  color: rgba(37, 99, 235, 1);
}

.contractBtn {
  width: 100%;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 1100;
  background: rgba(148, 163, 184, 0.10);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  color: rgba(51, 65, 85, 0.92);
}

.tabs {
  margin-top: 14rpx;
  background: rgba(148, 163, 184, 0.16);
  padding: 6rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  width: 480rpx;
}

.tab {
  flex: 1;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 1100;
  text-align: center;
  color: rgba(100, 116, 139, 0.9);
}

.tab-on {
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
  color: rgba(15, 23, 42, 0.85);
}

.body {
  padding: 18rpx 18rpx 0;
  flex: 1;
}

.emptyWrap {
  padding: 70rpx 0 40rpx;
  text-align: center;
}
.emptyIcon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  margin: 0 auto 20rpx;
  background: #fff;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 1200;
  color: rgba(148, 163, 184, 0.9);
}
.emptyTxt {
  font-size: 26rpx;
  font-weight: 900;
}
.emptyBtn {
  margin-top: 22rpx;
  width: 440rpx;
}

.pad {
  padding: 18rpx 18rpx 16rpx;
}

.mt-10 {
  margin-top: 10rpx;
}
.mt-12 {
  margin-top: 12rpx;
}
.mt-14 {
  margin-top: 14rpx;
}
.mt-16 {
  margin-top: 16rpx;
}

.pt-8 {
  padding-top: 8rpx;
}
.pb-10 {
  padding-bottom: 10rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.10);
  color: rgba(37, 99, 235, 1);
  border: 1rpx solid rgba(37, 99, 235, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 1200;
  font-size: 38rpx;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
    "Courier New", monospace;
}

.val {
  font-size: 26rpx;
  font-weight: 1100;
  color: rgba(15, 23, 42, 0.9);
  max-width: 420rpx;
  text-align: right;
}

.right {
  text-align: right;
}

.hr {
  height: 1rpx;
  background: rgba(148, 163, 184, 0.14);
}

.rentCard {
  border-color: rgba(37, 99, 235, 0.18);
}

.rentTitle {
  font-size: 26rpx;
  font-weight: 1200;
  color: rgba(30, 41, 59, 0.92);
}

.rentTitleBlue {
  color: rgba(30, 64, 175, 0.92);
}

.secIco {
  width: 34rpx;
  height: 34rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 1200;
}

.secIcoBlue {
  background: rgba(37, 99, 235, 0.12);
  color: rgba(37, 99, 235, 1);
}

.secIcoOra {
  background: rgba(234, 88, 12, 0.10);
  color: rgba(234, 88, 12, 1);
}

.rentSub {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.rentPaid {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(37, 99, 235, 0.95);
}

.bar {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
  overflow: hidden;
}

.barIn {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 1);
}

.gap-12 {
  gap: 12rpx;
}
.gap-16 {
  gap: 16rpx;
}
.gap-20 {
  gap: 20rpx;
}

.term {
  padding: 14rpx 14rpx 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.20);
  background: #fff;
}

.termName {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(51, 65, 85, 0.95);
}

.termRange {
  font-size: 18rpx;
}

.termLab {
  font-size: 18rpx;
  font-weight: 900;
}

.termAmt {
  font-size: 30rpx;
  font-weight: 1200;
  color: rgba(15, 23, 42, 0.92);
}

.okText {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(16, 185, 129, 1);
}

.boxPaid {
  background: rgba(16, 185, 129, 0.06);
  border-color: rgba(16, 185, 129, 0.20);
}

.boxOverdue {
  background: rgba(244, 63, 94, 0.06);
  border-color: rgba(244, 63, 94, 0.20);
}

.boxDue {
  background: rgba(37, 99, 235, 0.06);
  border-color: rgba(37, 99, 235, 0.20);
}

.tiny {
  font-size: 20rpx;
  font-weight: 900;
}

.warnBox {
  padding: 14rpx 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(244, 63, 94, 0.18);
  background: rgba(244, 63, 94, 0.06);
}

.warnTitle {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(225, 29, 72, 0.95);
}

.warnAmt {
  font-size: 22rpx;
  font-weight: 1200;
  color: rgba(225, 29, 72, 0.95);
}

.linkDanger {
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(148, 163, 184, 0.95);
  text-decoration: underline;
}

.uIco {
  margin-right: 6rpx;
  opacity: 0.85;
}

.utilsBtn {
  width: 100%;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 1100;
}

.secHead {
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.14);
  font-size: 22rpx;
  font-weight: 1100;
  color: rgba(100, 116, 139, 0.95);
  background: #fff;
  border-top-left-radius: 22rpx;
  border-top-right-radius: 22rpx;
}

.li {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.10);
}
.li:last-child {
  border-bottom: none;
}

.liTitle {
  font-size: 24rpx;
  font-weight: 1100;
  color: rgba(30, 41, 59, 0.92);
}

.liAmt {
  font-size: 26rpx;
  font-weight: 1200;
  color: rgba(30, 41, 59, 0.92);
}

.tlRow {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.tlDot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.55);
  margin-top: 12rpx;
  flex: 0 0 auto;
}

.tlDot.on {
  background: rgba(37, 99, 235, 0.85);
  box-shadow: 0 0 0 10rpx rgba(37, 99, 235, 0.10);
}

.tlBox {
  flex: 1;
  background: #fff;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 18rpx;
  padding: 14rpx 14rpx 12rpx;
}

/* Full-screen modals */
.fullOverlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(2, 6, 23, 0.92);
  z-index: 700;
  display: flex;
  flex-direction: column;
}

.fullHead {
  padding: 18rpx 18rpx 14rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.fullHead.light {
  background: rgba(255, 255, 255, 0.96);
  color: rgba(15, 23, 42, 0.92);
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.fullTitle {
  font-size: 30rpx;
  font-weight: 1200;
}

.fullClose {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.fullClose.gray {
  background: rgba(148, 163, 184, 0.14);
  color: rgba(100, 116, 139, 0.95);
}

.fullBody {
  flex: 1;
}

.fullFoot {
  padding: 16rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.full {
  width: 100%;
}

.contractEmpty {
  margin-top: 160rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.62);
}

.contractIcon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: 1200;
}

.contractCard {
  width: 660rpx;
  margin: 80rpx auto 0;
  border-radius: 18rpx;
  background: #fff;
  padding: 12rpx;
  position: relative;
  overflow: hidden;
}

.watermark {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(15, 23, 42, 0.10);
  font-weight: 1200;
  font-size: 34rpx;
  transform: rotate(-18deg);
  border: 6rpx solid rgba(15, 23, 42, 0.08);
  margin: 60rpx;
  border-radius: 16rpx;
  pointer-events: none;
}

.contractMock {
  height: 720rpx;
  border-radius: 14rpx;
  background: rgba(241, 245, 249, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(148, 163, 184, 0.9);
  font-weight: 1100;
}

.stepTitle {
  font-size: 22rpx;
  font-weight: 1200;
  color: rgba(30, 41, 59, 0.92);
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.14);
}

.stepTitle.blue {
  color: rgba(37, 99, 235, 1);
}

.stepTitle.danger {
  color: rgba(225, 29, 72, 1);
}

.pick {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: #fff;
  font-weight: 1100;
}

.inp {
  width: 340rpx;
  text-align: right;
  padding: 10rpx 0;
  font-weight: 1100;
}

.seg {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: rgba(148, 163, 184, 0.16);
}

.seg-btn {
  flex: 1;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 1100;
  text-align: center;
  color: rgba(100, 116, 139, 0.9);
}

.seg-on {
  background: #fff;
  color: rgba(37, 99, 235, 1);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.upload {
  margin-top: 14rpx;
  padding: 30rpx 18rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(148, 163, 184, 0.40);
  background: rgba(241, 245, 249, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(100, 116, 139, 0.85);
}

.upload-on {
  border-color: rgba(16, 185, 129, 0.55);
  background: rgba(236, 253, 245, 0.8);
  color: rgba(16, 185, 129, 1);
}

.uploadIcon {
  font-size: 44rpx;
  font-weight: 1200;
}

.uploadTxt {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 1100;
}

.payBox {
  border-color: rgba(37, 99, 235, 0.20);
  background: rgba(37, 99, 235, 0.05);
}

.dashHr {
  border-top: 1rpx dashed rgba(37, 99, 235, 0.30);
}

.blueTiny {
  font-size: 20rpx;
  font-weight: 1100;
  color: rgba(37, 99, 235, 1);
}

.actual {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border: 1rpx solid rgba(37, 99, 235, 0.25);
  border-radius: 14rpx;
  padding: 8rpx 12rpx;
}

.actualSign {
  font-size: 30rpx;
  font-weight: 1200;
  color: rgba(37, 99, 235, 1);
}

.actualInp {
  width: 160rpx;
  text-align: right;
  font-size: 34rpx;
  font-weight: 1200;
  color: rgba(37, 99, 235, 1);
  padding: 0;
  margin-left: 6rpx;
}

.ta {
  width: 100%;
  min-height: 180rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 14rpx;
  padding: 14rpx 14rpx;
  background: #fff;
  box-sizing: border-box;
}

.tipDanger {
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(254, 226, 226, 0.7);
  border: 1rpx solid rgba(244, 63, 94, 0.18);
  color: rgba(225, 29, 72, 0.95);
  font-size: 22rpx;
  font-weight: 1100;
}

.dangerText {
  color: rgba(225, 29, 72, 0.95);
}

.tpl {
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 18rpx;
  background: rgba(241, 245, 249, 0.8);
  padding: 16rpx 14rpx;
  font-size: 22rpx;
  white-space: pre-wrap;
  color: rgba(51, 65, 85, 0.92);
}

.bigAmt {
  font-size: 46rpx;
  font-weight: 1200;
  color: rgba(37, 99, 235, 1);
}
