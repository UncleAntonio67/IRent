.box {
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  padding: 26rpx 24rpx 22rpx;
}

.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.mt-16 {
  margin-top: 16rpx;
}

.mt-18 {
  margin-top: 18rpx;
}

.flex1 {
  flex: 1;
}

.inp {
  width: 100%;
  border: 1rpx solid var(--border);
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 16rpx;
  font-weight: 900;
  box-sizing: border-box;
}

